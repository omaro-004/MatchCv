{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block auth_body %}
<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">
            <div class="auth-logo-icon">
                <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                    <rect x="2" y="7" width="20" height="14" rx="2"/>
                    <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                </svg>
                <div class="auth-logo-badge">
                    <svg width="10" height="10" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
            </div>
            <h1>Match<span>CV</span></h1>
            <p>Trouvez le match parfait pour votre carrière</p>
        </div>

        {% if error is defined and error %}
            <div class="flash flash-error" style="margin-bottom:16px;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label for="email">Adresse e-mail</label>
                <div class="input-icon-wrap">
                    <svg class="input-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/>
                    </svg>
                    <input
                        class="form-control"
                        type="email"
                        id="email"
                        name="_username"
                        value="{{ last_username is defined ? last_username : '' }}"
                        placeholder="vous@exemple.com"
                        autocomplete="email"
                        required
                    >
                </div>
            </div>

            <div class="form-group">
                <div class="flex justify-between items-center" style="margin-bottom:6px;">
                    <label for="password" style="margin-bottom:0;">Mot de passe</label>
                    <a href="{{ path('app_forgot_password') }}" style="font-size:.8rem;color:var(--accent);font-weight:500;">
                        Mot de passe oublié ?
                    </a>
                </div>
                <div class="input-icon-wrap">
                    <svg class="input-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input
                        class="form-control"
                        type="password"
                        id="password"
                        name="_password"
                        placeholder="••••••••"
                        autocomplete="current-password"
                        required
                    >
                    <svg class="input-icon-right" id="toggle-password" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" onclick="togglePassword()">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:8px;">
                Se connecter
            </button>
        </form>

        <div class="divider">ou continuer avec</div>

        {# ── Connexion / inscription automatique candidat via OAuth ── #}
        <div class="form-row">
            <a href="{{ path('app_oauth_github_start') }}" class="btn btn-secondary" style="justify-content:center;gap:8px;">
                <svg width="17" height="17" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                Continuer avec GitHub
            </a>
            <a href="{{ path('app_oauth_linkedin_start') }}" class="btn btn-secondary" style="justify-content:center;gap:8px;">
                <svg width="17" height="17" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                Continuer avec LinkedIn
            </a>
        </div>
        <div style="text-align:center;font-size:.72rem;color:var(--text-muted);margin-top:8px;margin-bottom:18px;">
            Réservé aux candidats — un compte est créé automatiquement si besoin.
        </div>

        <a href="{{ path('app_inscription_choice') }}" class="btn btn-secondary btn-full" style="justify-content:center;">
            Créer un compte
        </a>

    </div>
</div>

<script>
function togglePassword() {
    const input = document.getElementById('password');
    input.type = input.type === 'password' ? 'text' : 'password';
}
</script>
{% endblock %}
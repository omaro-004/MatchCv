{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block auth_body %}
<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">
            <div class="auth-logo-icon">
                <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                    <rect x="2" y="7" width="20" height="14" rx="2"/>
                    <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                </svg>
                <div class="auth-logo-badge">
                    <svg width="10" height="10" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
            </div>
            <h1>Match<span>CV</span></h1>
            <p>Trouvez le match parfait pour votre carrière</p>
        </div>

        {% if error is defined and error %}
            <div class="flash flash-error" style="margin-bottom:16px;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label for="email">Adresse e-mail</label>
                <div class="input-icon-wrap">
                    <svg class="input-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/>
                    </svg>
                    <input
                        class="form-control"
                        type="email"
                        id="email"
                        name="_username"
                        value="{{ last_username is defined ? last_username : '' }}"
                        placeholder="vous@exemple.com"
                        autocomplete="email"
                        required
                    >
                </div>
            </div>

            <div class="form-group">
                <div class="flex justify-between items-center" style="margin-bottom:6px;">
                    <label for="password" style="margin-bottom:0;">Mot de passe</label>
                    <a href="{{ path('app_forgot_password') }}" style="font-size:.8rem;color:var(--accent);font-weight:500;">
                        Mot de passe oublié ?
                    </a>
                </div>
                <div class="input-icon-wrap">
                    <svg class="input-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input
                        class="form-control"
                        type="password"
                        id="password"
                        name="_password"
                        placeholder="••••••••"
                        autocomplete="current-password"
                        required
                    >
                    <svg class="input-icon-right" id="toggle-password" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" onclick="togglePassword()">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:8px;">
                Se connecter
            </button>
        </form>

        <div class="divider">ou</div>

        <a href="{{ path('app_inscription_choice') }}" class="btn btn-secondary btn-full" style="justify-content:center;">
            Créer un compte
        </a>

    </div>
</div>

<script>
function togglePassword() {
    const input = document.getElementById('password');
    input.type = input.type === 'password' ? 'text' : 'password';
}
</script>
{% endblock %}

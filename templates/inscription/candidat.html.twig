{% extends 'base.html.twig' %}

{% block title %}Inscription candidat{% endblock %}

{% block auth_body %}
{% macro field_error(field) %}
    {% if field.vars.errors|length %}
        <div class="form-error">
            {{ form_errors(field) }}
        </div>
    {% endif %}
{% endmacro %}

<div class="auth-wrapper" style="padding: 40px 24px;">
    <div class="auth-card" style="max-width:560px;">

        <div style="display:flex;align-items:center;gap:14px;margin-bottom:28px;">
            <a href="{{ path('app_inscription_choice') }}" style="color:var(--text-muted);display:flex;align-items:center;gap:4px;font-size:.82rem;transition:color .15s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5m7-7l-7 7 7 7"/></svg>
                Retour
            </a>
        </div>

        <div style="margin-bottom:24px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
                <div style="width:36px;height:36px;background:rgba(99,102,241,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">🎓</div>
                <div>
                    <div style="font-size:1.1rem;font-weight:800;color:var(--text-primary);">Créer un compte candidat</div>
                    <div style="font-size:.8rem;color:var(--text-secondary);">Accédez aux offres matchées par l'IA</div>
                </div>
            </div>
        </div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-row">
                <div class="form-group">
                    <label>{{ form_label(form.email) }}</label>
                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'vous@exemple.com'}}) }}
                    {{ _self.field_error(form.email) }}
                </div>
                <div class="form-group">
                    <label>Nom complet</label>
                    {{ form_widget(form.nomComplet, {'attr': {'class': 'form-control', 'placeholder': 'Sophie Laurent'}}) }}
                    {{ _self.field_error(form.nomComplet) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Mot de passe</label>
                    {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': '8 caractères minimum'}}) }}
                    {{ _self.field_error(form.plainPassword.first) }}
                </div>
                <div class="form-group">
                    <label>Confirmer le mot de passe</label>
                    {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Répétez le mot de passe'}}) }}
                    {{ _self.field_error(form.plainPassword.second) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Téléphone</label>
                    {{ form_widget(form.numTel, {'attr': {'class': 'form-control', 'placeholder': '+33 6 00 00 00 00'}}) }}
                    {{ _self.field_error(form.numTel) }}
                </div>
                <div class="form-group">
                    <label>Localisation</label>
                    {{ form_widget(form.localisation, {'attr': {'class': 'form-control', 'placeholder': 'Paris, France'}}) }}
                    {{ _self.field_error(form.localisation) }}
                </div>
            </div>

            <div class="form-group">
                <label>Type de contrat recherché</label>
                {{ form_widget(form.typeContrat, {'attr': {'class': 'form-control filter-select', 'style': 'cursor:pointer;'}}) }}
                {{ _self.field_error(form.typeContrat) }}
            </div>

            <div class="form-group">
                <label>
                    CV (PDF)
                </label>
                <div style="border:2px dashed var(--border);border-radius:var(--radius-sm);padding:20px;text-align:center;transition:border-color .2s;cursor:pointer;" id="cv-drop-zone">
                    <svg width="24" height="24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 8px;display:block;">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                        <line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
                    </svg>
                    <p style="font-size:.82rem;color:var(--text-secondary);margin-bottom:4px;">Glissez votre CV ici ou cliquez pour parcourir</p>
                    <p style="font-size:.74rem;color:var(--text-muted);">Format PDF uniquement · Max 5 Mo</p>
                    {{ form_widget(form.cv, {'attr': {'class': 'form-control', 'style': 'margin-top:10px;', 'accept': 'application/pdf'}}) }}
                </div>
                {{ _self.field_error(form.cv) }}
            </div>

            <div class="form-group">
                <label>Bio <span style="color:var(--text-muted);font-weight:400;">(optionnel)</span></label>
                {{ form_widget(form.bio, {'attr': {'class': 'form-control', 'placeholder': 'Parlez de vous, de vos compétences et de vos projets...', 'rows': '3'}}) }}
                {{ _self.field_error(form.bio) }}
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>LinkedIn <span style="color:var(--text-muted);font-weight:400;">(optionnel)</span></label>
                    {{ form_widget(form.lienLinkedin, {'attr': {'class': 'form-control', 'placeholder': 'https://linkedin.com/in/...'}}) }}
                    {{ _self.field_error(form.lienLinkedin) }}
                </div>
                <div class="form-group">
                    <label>Autres liens <span style="color:var(--text-muted);font-weight:400;">(optionnel)</span></label>
                    {{ form_widget(form.autresLiens, {'attr': {'class': 'form-control', 'placeholder': 'GitHub, portfolio...'}}) }}
                    {{ _self.field_error(form.autresLiens) }}
                </div>
            </div>

            <div class="form-group">
                <label>Photo de profil</label>
                {{ form_widget(form.photo, {'attr': {'class': 'form-control', 'accept': 'image/*'}}) }}
                {{ _self.field_error(form.photo) }}
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:8px;">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                Créer mon compte candidat
            </button>

        {{ form_end(form) }}

        <div style="text-align:center;margin-top:20px;">
            <span style="font-size:.83rem;color:var(--text-secondary);">Déjà un compte ?</span>
            <a href="{{ path('app_login') }}" style="font-size:.83rem;color:var(--accent);font-weight:600;margin-left:4px;">Se connecter</a>
        </div>

    </div>
</div>
{% endblock %}

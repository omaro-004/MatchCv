{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block auth_body %}
<div class="auth-wrapper">
    <div class="auth-card">

        <div style="margin-bottom:24px;">
            <div style="width:48px;height:48px;background:rgba(34,197,94,.1);border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                <svg width="22" height="22" fill="none" stroke="var(--success)" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
            </div>
            <div style="font-size:1.1rem;font-weight:800;color:var(--text-primary);margin-bottom:4px;">Nouveau mot de passe</div>
            <div style="font-size:.84rem;color:var(--text-secondary);">Choisissez un mot de passe sécurisé d'au moins 8 caractères.</div>
        </div>

        <form method="post" action="{{ path('app_reset_password', {'token': token}) }}" novalidate>

            <div class="form-group">
                <label for="new_password">Nouveau mot de passe</label>
                <div class="input-icon-wrap">
                    <svg class="input-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <input class="form-control" type="password" id="new_password" name="password[first]" placeholder="8 caractères minimum" required>
                </div>
            </div>

            <div class="form-group">
                <label for="confirm_password">Confirmer le mot de passe</label>
                <div class="input-icon-wrap">
                    <svg class="input-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <input class="form-control" type="password" id="confirm_password" name="password[second]" placeholder="Répétez le mot de passe" required>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:8px;">
                Réinitialiser le mot de passe
            </button>

        </form>

    </div>
</div>
{% endblock %}

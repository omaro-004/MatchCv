            <div style="position:relative;">
                <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" placeholder="Rechercher une offre..." style="padding:8px 12px 8px 32px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:.83rem;outline:none;font-family:inherit;width:220px;color:var(--text-primary);">
            </div>
            <div style="display:flex;gap:6px;">
                <button class="btn btn-primary btn-sm active" style="border-radius:999px;">Toutes</button>
                <button class="btn btn-secondary btn-sm" style="border-radius:999px;">Actives</button>
                <button class="btn btn-secondary btn-sm" style="border-radius:999px;">Clôturées</button>
                <button class="btn btn-secondary btn-sm" style="border-radius:999px;">Expirées</button>

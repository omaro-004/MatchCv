{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block auth_body %}
<div class="auth-wrapper">
    <div class="auth-card">

        <div style="margin-bottom:24px;">
            <a href="{{ path('app_login') }}" style="color:var(--text-muted);display:inline-flex;align-items:center;gap:5px;font-size:.82rem;margin-bottom:20px;transition:color .15s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-muted)'">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5m7-7l-7 7 7 7"/></svg>
                Retour à la connexion
            </a>
            <div style="width:48px;height:48px;background:rgba(99,102,241,.1);border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                <svg width="22" height="22" fill="none" stroke="var(--accent)" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div style="font-size:1.1rem;font-weight:800;color:var(--text-primary);margin-bottom:4px;">Mot de passe oublié ?</div>
            <div style="font-size:.84rem;color:var(--text-secondary);line-height:1.5;">Saisissez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.</div>
        </div>

        <form method="post" action="{{ path('app_forgot_password') }}" novalidate>

            <div class="form-group">
                <label for="email">Adresse e-mail</label>
                <div class="input-icon-wrap">
                    <svg class="input-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/>
                    </svg>
                    <input class="form-control" type="email" id="email" name="email" placeholder="vous@exemple.com" required>
                </div>
                <div class="form-hint">Un lien valable 24h vous sera envoyé à cette adresse.</div>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:8px;">
                Envoyer le lien de réinitialisation
            </button>

        </form>

    </div>
</div>
{% endblock %}

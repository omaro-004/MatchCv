{# templates/face_id/verify.html.twig
   Page de vérification faciale lors du login.
   Affiché uniquement si face_id_enabled = true (LoginSuccessHandler).
   L'utilisateur est déjà authentifié (email/password OK) mais l'accès
   aux routes protégées est bloqué par FaceIdListener jusqu'à ce que
   la session 'face_id_verified' soit mise à true.
#}
{% extends 'base.html.twig' %}

{% block title %}Vérification Face ID{% endblock %}

{% block auth_body %}
<div class="auth-wrapper" style="background:linear-gradient(135deg,#f0f1ff 0%,#fafafa 60%,#eff6ff 100%);">
    <div class="auth-card" style="max-width:480px;">

        {# ── En-tête ── #}
        <div class="auth-logo" style="margin-bottom:20px;">
            <div class="auth-logo-icon" style="background:linear-gradient(135deg,#6366f1,#4f46e5);">
                <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M3 9a2 2 0 0 1 2-2h.93a2 2 0 0 0 1.664-.89l.812-1.22A2 2 0 0 1 10.07 4h3.86a2 2 0 0 1 1.664.89l.812 1.22A2 2 0 0 0 18.07 7H19a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/>
                </svg>
                <div class="auth-logo-badge">
                    <svg width="10" height="10" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>
            </div>
            <h1>Vérification <span>Face ID</span></h1>
            <p>Bonjour {{ user_nom|split(' ')|first }} — Confirmez votre identité pour continuer</p>
        </div>

        {# ── Statut du modèle ── #}
        <div id="model-status" style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:rgba(99,102,241,.07);border:1px solid rgba(99,102,241,.2);border-radius:var(--radius-sm);font-size:.82rem;color:var(--accent);margin-bottom:20px;">
            <span id="model-spinner" style="display:inline-block;width:14px;height:14px;border:2px solid var(--accent);border-top-color:transparent;border-radius:50%;animation:spin .8s linear infinite;flex-shrink:0;"></span>
            <span id="model-status-text">Chargement du modèle IA…</span>
        </div>

        {# ── Zone vidéo ── #}
        <div id="video-container" style="position:relative;width:100%;border-radius:var(--radius-md);overflow:hidden;background:#0f172a;margin-bottom:20px;display:none;">
            <video id="video" autoplay muted playsinline style="width:100%;display:block;border-radius:var(--radius-md);"></video>
            <canvas id="overlay" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;"></canvas>

            {# Cadre ovale de guidage #}
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:160px;height:200px;border:2px dashed rgba(99,102,241,.6);border-radius:50%;pointer-events:none;"></div>

            {# Badge de statut #}
            <div id="detection-badge" style="position:absolute;bottom:12px;left:50%;transform:translateX(-50%);padding:5px 14px;border-radius:999px;font-size:.78rem;font-weight:600;background:rgba(15,23,42,.75);color:#e2e8f0;backdrop-filter:blur(4px);white-space:nowrap;">
                Positionnez votre visage dans le cadre
            </div>
        </div>

        {# ── Barre de progression de la vérification ── #}
        <div id="verify-progress" style="display:none;margin-bottom:20px;">
            <div style="display:flex;justify-content:space-between;font-size:.78rem;color:var(--text-secondary);margin-bottom:6px;">
                <span id="verify-label">Analyse en cours…</span>
                <span id="verify-pct">0%</span>
            </div>
            <div style="height:6px;background:var(--border);border-radius:999px;overflow:hidden;">
                <div id="verify-bar" style="height:100%;width:0%;background:var(--accent);border-radius:999px;transition:width .4s,background .4s;"></div>
            </div>
        </div>

        {# ── Feedback ── #}
        <div id="feedback" style="display:none;margin-bottom:20px;padding:12px 16px;border-radius:var(--radius-sm);font-size:.84rem;font-weight:500;"></div>

        {# ── Boutons ── #}
        <div id="actions" style="display:flex;flex-direction:column;gap:10px;">
            <button id="btn-verify" class="btn btn-primary btn-full btn-lg" disabled>
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M3 9a2 2 0 0 1 2-2h.93a2 2 0 0 0 1.664-.89l.812-1.22A2 2 0 0 1 10.07 4h3.86a2 2 0 0 1 1.664.89l.812 1.22A2 2 0 0 0 18.07 7H19a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/>
                </svg>
                Vérifier mon identité
            </button>

            <button id="btn-fallback" class="btn btn-secondary btn-full" style="font-size:.83rem;">
                Je ne peux pas utiliser la caméra — me déconnecter
            </button>
        </div>

        <p style="text-align:center;font-size:.76rem;color:var(--text-muted);margin-top:16px;line-height:1.5;">
            La vérification se fait entièrement dans votre navigateur.<br>
            Aucune image n'est envoyée vers nos serveurs.
        </p>

    </div>
</div>

<style>
    @keyframes spin { to { transform: rotate(360deg); } }
</style>

{# Descripteur de référence stocké en base, passé par le contrôleur #}
<script>
// ============================================================
//  DESCRIPTEUR DE RÉFÉRENCE (depuis la base de données)
//  Injecté par FaceIdController::verifyPage() via Twig.
//  C'est le tableau de 128 floats enregistré lors de l'inscription.
// ============================================================
const REFERENCE_DESCRIPTOR = new Float32Array({{ face_descriptor_json|raw }});
const MODELS_PATH           = '/models';
const VALIDATE_URL          = '{{ path("app_face_id_validate") }}';
const FALLBACK_URL          = '{{ path("app_face_id_fallback") }}';
const CSRF_TOKEN_VALIDATE   = '{{ csrf_token("face_id_validate") }}';
const CSRF_TOKEN_FALLBACK   = '{{ csrf_token("face_id_fallback") }}';
const DISTANCE_THRESHOLD    = 0.5;   // Même seuil que le contrôleur

// ============================================================
//  ÉTAT
// ============================================================
let modelsLoaded  = false;
let stream        = null;
let detectionLoop = null;
let lastDetection = null;  // Dernière détection valide

// ============================================================
//  RÉFÉRENCES DOM
// ============================================================
const $ = id => document.getElementById(id);
const modelStatus     = $('model-status');
const modelStatusText = $('model-status-text');
const modelSpinner    = $('model-spinner');
const videoContainer  = $('video-container');
const video           = $('video');
const overlay         = $('overlay');
const detectionBadge  = $('detection-badge');
const verifyProgress  = $('verify-progress');
const verifyBar       = $('verify-bar');
const verifyLabel     = $('verify-label');
const verifyPct       = $('verify-pct');
const feedbackDiv     = $('feedback');
const btnVerify       = $('btn-verify');
const btnFallback     = $('btn-fallback');

// ============================================================
//  CHARGEMENT DES MODÈLES
// ============================================================
async function loadModels() {
    try {
        await Promise.all([
            faceapi.nets.tinyFaceDetector.loadFromUri(MODELS_PATH),
            faceapi.nets.faceRecognitionNet.loadFromUri(MODELS_PATH),
        ]);
        modelsLoaded = true;
        modelSpinner.style.display = 'none';
        modelStatusText.textContent = 'Modèle prêt. Démarrage de la caméra…';
        modelStatus.style.background = 'rgba(34,197,94,.07)';
        modelStatus.style.borderColor = 'rgba(34,197,94,.2)';
        modelStatus.style.color = 'var(--success)';

        await startCamera();
    } catch (err) {
        console.error('Erreur modèles :', err);
        modelStatusText.textContent = 'Impossible de charger le modèle IA.';
        modelSpinner.style.display = 'none';
        modelStatus.style.color = 'var(--danger)';
    }
}

// ============================================================
//  CAMÉRA
// ============================================================
async function startCamera() {
    try {
        stream = await navigator.mediaDevices.getUserMedia({
            video: { width: { ideal: 480 }, height: { ideal: 360 }, facingMode: 'user' },
            audio: false,
        });
        video.srcObject = stream;
        await new Promise(resolve => { video.onloadedmetadata = resolve; });
        videoContainer.style.display = 'block';
        overlay.width  = video.videoWidth;
        overlay.height = video.videoHeight;
        startDetectionLoop();
    } catch (err) {
        console.warn('Caméra inaccessible :', err);
        showFeedback('Impossible d\'accéder à la caméra. Utilisez le bouton de déconnexion ci-dessous.', 'error');
    }
}

function stopCamera() {
    if (detectionLoop) { clearInterval(detectionLoop); detectionLoop = null; }
    if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
    video.srcObject = null;
}

// ============================================================
//  BOUCLE DE DÉTECTION CONTINUE
// ============================================================
function startDetectionLoop() {
    const options = new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.5 });

    detectionLoop = setInterval(async () => {
        if (!modelsLoaded || video.readyState < 2) return;

        const detection = await faceapi
            .detectSingleFace(video, options)
            .withFaceDescriptor();

        const ctx = overlay.getContext('2d');
        ctx.clearRect(0, 0, overlay.width, overlay.height);

        if (detection) {
            // Dessiner le rectangle de détection
            const { x, y, width, height } = detection.detection.box;
            const sx = overlay.width / video.videoWidth;
            const sy = overlay.height / video.videoHeight;
            ctx.strokeStyle = 'rgba(34,197,94,.9)';
            ctx.lineWidth = 2;
            ctx.strokeRect(x * sx, y * sy, width * sx, height * sy);

            lastDetection = detection;
            detectionBadge.textContent = '✓ Visage détecté — cliquez sur "Vérifier"';
            detectionBadge.style.color = '#86efac';
            btnVerify.disabled = false;
        } else {
            lastDetection = null;
            detectionBadge.textContent = 'Positionnez votre visage dans le cadre';
            detectionBadge.style.color = '#e2e8f0';
            btnVerify.disabled = true;
        }
    }, 300);
}

// ============================================================
//  VÉRIFICATION FACIALE
// ============================================================
btnVerify.addEventListener('click', async () => {
    if (!lastDetection) {
        showFeedback('Aucun visage détecté. Repositionnez-vous et réessayez.', 'error');
        return;
    }

    btnVerify.disabled = true;
    btnFallback.disabled = true;
    verifyProgress.style.display = 'block';
    verifyLabel.textContent = 'Comparaison en cours…';

    // Prendre 3 mesures et moyenner
    const options = new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.5 });
    const descriptors = [];
    for (let i = 0; i < 3; i++) {
        const d = await faceapi.detectSingleFace(video, options).withFaceDescriptor();
        if (d) descriptors.push(d.descriptor);
        verifyBar.style.width = ((i + 1) / 3 * 50) + '%';
        verifyPct.textContent = Math.round((i + 1) / 3 * 50) + '%';
        await new Promise(r => setTimeout(r, 200));
    }

    if (descriptors.length === 0) {
        showFeedback('Échec de la capture. Assurez-vous d\'être bien éclairé.', 'error');
        verifyProgress.style.display = 'none';
        btnVerify.disabled = false;
        btnFallback.disabled = false;
        return;
    }

    // Calculer la distance euclidienne entre le descripteur moyen et la référence
    const avgDescriptor = new Float32Array(128);
    for (const d of descriptors) {
        for (let i = 0; i < 128; i++) avgDescriptor[i] += d[i] / descriptors.length;
    }

    verifyBar.style.width = '75%';
    verifyPct.textContent = '75%';
    verifyLabel.textContent = 'Comparaison avec le profil enregistré…';

    const distance = faceapi.euclideanDistance(Array.from(avgDescriptor), Array.from(REFERENCE_DESCRIPTOR));
    const verified = distance <= DISTANCE_THRESHOLD;

    verifyBar.style.width = '100%';
    verifyBar.style.background = verified ? 'var(--success)' : 'var(--danger)';
    verifyPct.textContent = '100%';
    verifyLabel.textContent = verified ? 'Identité confirmée ✓' : 'Non reconnu';

    // Envoyer le résultat au serveur pour validation finale + mise à jour session
    try {
        const response = await fetch(VALIDATE_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': CSRF_TOKEN_VALIDATE,
            },
            body: JSON.stringify({ verified, distance }),
        });

        const data = await response.json();

        if (data.success) {
            showFeedback('Identité vérifiée avec succès ! Redirection…', 'success');
            stopCamera();
            setTimeout(() => { window.location.href = data.redirect; }, 1000);
        } else {
            showFeedback(data.error || 'Visage non reconnu. Réessayez.', 'error');
            verifyProgress.style.display = 'none';
            btnVerify.disabled = false;
            btnFallback.disabled = false;
        }
    } catch (err) {
        console.error(err);
        showFeedback('Erreur réseau. Réessayez.', 'error');
        verifyProgress.style.display = 'none';
        btnVerify.disabled = false;
        btnFallback.disabled = false;
    }
});

// ============================================================
//  BOUTON FALLBACK (déconnexion)
// ============================================================
btnFallback.addEventListener('click', async () => {
    if (!confirm('Voulez-vous vous déconnecter ? Vous devrez vous reconnecter et passer la vérification Face ID.')) return;

    try {
        const response = await fetch(FALLBACK_URL, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': CSRF_TOKEN_FALLBACK,
            },
            body: JSON.stringify({}),
        });
        const data = await response.json();
        if (data.redirect) window.location.href = data.redirect;
    } catch (err) {
        window.location.href = '/deconnexion';
    }
});

// ============================================================
//  HELPER FEEDBACK
// ============================================================
function showFeedback(message, type) {
    feedbackDiv.style.display    = 'block';
    feedbackDiv.textContent      = message;
    feedbackDiv.style.background = type === 'success' ? 'rgba(34,197,94,.1)'  : 'rgba(239,68,68,.1)';
    feedbackDiv.style.border     = type === 'success' ? '1px solid rgba(34,197,94,.25)' : '1px solid rgba(239,68,68,.25)';
    feedbackDiv.style.color      = type === 'success' ? '#15803d' : '#b91c1c';
}

// ============================================================
//  INIT
// ============================================================
document.addEventListener('DOMContentLoaded', loadModels);
</script>

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
{% endblock %}
